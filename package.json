{
  "name": "@sophiaxt/sophia-stack",
  "version": "1.0.0",
  "description": "Open-source, self-hosted, provider-agnostic AI app builder from SophiaXT Tech. Own your site and operate it with any AI (OpenAI, Anthropic, Gemini, or local) via REST, MCP, and OpenAPI. Extensible, agent-operable, no SaaS lock-in.",
  "type": "module",
  "bin": {
    "sophia": "./bin/sophia.mjs"
  },
  "scripts": {
    "demo": "node demo/demo.mjs",
    "build": "node scripts/build.mjs",
    "catalog": "node scripts/catalog.mjs",
    "dev": "node scripts/dev.mjs",
    "serve": "node scripts/serve.mjs",
    "package": "node scripts/package.mjs",
    "doctor": "node bin/sophia.mjs doctor",
    "test": "node demo/run-all.mjs",
    "test:package": "node scripts/package.mjs && node demo/package-test.mjs"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  },
  "keywords": [
    "ai",
    "ai-app-builder",
    "self-hosted",
    "open-source",
    "website-builder",
    "mcp",
    "openapi",
    "ai-agents",
    "lovable-alternative",
    "base44-alternative",
    "no-lock-in",
    "sophiaxt"
  ],
  "author": "SophiaXT LLC",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Chorozion/Sophia-Stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chorozion/Sophia-Stack.git"
  },
  "bugs": {
    "url": "https://github.com/Chorozion/Sophia-Stack/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
