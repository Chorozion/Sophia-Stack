# Sophia Stack — environment configuration (example)
# Copy to .env and fill in. NEVER commit real keys. .env is gitignored.
# You can also configure the AI provider in the dashboard (Settings) instead of here.
#
# The built-in AI builder is PROVIDER-AGNOSTIC. Set whichever provider(s) you use;
# pick the active one with SOPHIA_AI_PROVIDER (else the first one found is used).

SOPHIA_AI_PROVIDER=openai

# ── Hosted providers ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro

OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini

GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=

# ── Local models (OpenAI-compatible servers — no key needed) ─────────────────
# Ollama:    OLLAMA_BASE_URL=http://localhost:11434/v1   OLLAMA_MODEL=llama3.1
# LM Studio: LMSTUDIO_BASE_URL=http://localhost:1234/v1  LMSTUDIO_MODEL=local-model
# vLLM:      VLLM_BASE_URL=http://localhost:8000/v1      VLLM_MODEL=your-model
# OLLAMA_BASE_URL=
# LMSTUDIO_BASE_URL=
# VLLM_BASE_URL=

# ── Any custom OpenAI-compatible endpoint ────────────────────────────────────
# CUSTOM_AI_TYPE=openai          # openai | anthropic | gemini
# CUSTOM_AI_BASE_URL=
# CUSTOM_AI_API_KEY=
# CUSTOM_AI_MODEL=

# ── Payments (YOUR own Stripe — to sell to your customers; Sophia takes no cut) ──
# Or connect it in the dashboard: Settings → Payments. Use TEST keys first.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_CURRENCY=usd

# ── Updates (pull-based; data auto-migrates non-destructively on the new code) ──
# SOPHIA_UPDATE_CHECK=off          # disable update checks entirely
# SOPHIA_UPDATE_URL=https://api.github.com/repos/OWNER/REPO/releases/latest   # custom channel

# ── Runtime ──────────────────────────────────────────────────────────────────
# PORT is set by your host (numeric TCP, or a Unix socket path on Passenger/Hostinger).
# PORT=3000
